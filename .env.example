# Porta do servidor
PORT=3000

# Token de autenticação para upload
UPLOAD_TOKEN=seu-token-secreto-aqui

# Tamanho máximo por arquivo em bytes (padrão no código: 100 MiB = 104857600)
MAX_FILE_SIZE=104857600

# MongoDB — conexão e armazenamento dos arquivos (GridFS)
# Exemplo com TLS desligado: mongodb://usuario:senha@host:27019/nomeDoBanco?authSource=admin&tls=false
MONGODB_URI=

# Nome do bucket GridFS (opcional, padrão: mediaFs)
# GRIDFS_BUCKET_NAME=mediaFs
