# Porta do servidor
PORT=3000

# Token de autenticação para upload
UPLOAD_TOKEN=seu-token-secreto-aqui

# Tamanho máximo de arquivo em bytes (padrão: 100MB)
MAX_FILE_SIZE=104857600

# MongoDB — metadados dos uploads (obrigatório em produção)
